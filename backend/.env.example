# Shared secret with the Next.js app (REQUIRED in production — the API guard
# fails closed without it). Generate: openssl rand -hex 32
BACKEND_API_KEY="generate-a-strong-random-secret"

# Anthropic key for Claude Vision extraction of scanned PDFs.
ANTHROPIC_API_KEY="sk-ant-..."

# Allowed browser origin for CORS (the deployed web app URL).
WEB_URL="http://localhost:3000"

# Set to "production" or "staging" in deployed environments so the API key
# guard is enforced. Defaults to development locally.
APP_ENV="development"

# Bind address / port for `python main.py` (defaults to 127.0.0.1:8000).
# Override HOST=0.0.0.0 only if the platform requires it.
# HOST="127.0.0.1"
# PORT="8000"
