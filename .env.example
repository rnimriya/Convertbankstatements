# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bankstatements?schema=public"

# ─── Auth (Supabase) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_PAYG="price_..."          # $1.99 one-time
STRIPE_PRICE_PRO_MONTHLY="price_..."   # $48/mo
STRIPE_PRICE_BUSINESS_MONTHLY="price_..." # $98/mo

# ─── Razorpay (live billing) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."
# Subscription plan IDs — create each plan in the Razorpay dashboard, then paste its id.
RAZORPAY_PLAN_BASIC_MONTHLY="plan_..."      # ₹25 / month, 25 pages (REQUIRED for the Basic plan)
RAZORPAY_PLAN_BASIC_ANNUAL="plan_..."       # ₹248 / year, 25 pages/mo
RAZORPAY_PLAN_PRO_MONTHLY="plan_..."        # ₹1,198 / month
RAZORPAY_PLAN_PRO_ANNUAL="plan_..."         # ₹11,499 / year
RAZORPAY_PLAN_BUSINESS_MONTHLY="plan_..."   # ₹4,498 / month
RAZORPAY_PLAN_BUSINESS_ANNUAL="plan_..."    # ₹43,178 / year

# ─── FastAPI Backend ─────────────────────────────────────────────────────────
BACKEND_URL_SERVER="http://localhost:8000"
BACKEND_API_KEY="generate-a-strong-random-secret"

# ─── AI / LLM (for 1000+ bank support via Vision LLM) ────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."  # Fallback option

# ─── Google Sheets ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-random-secret"
# Do NOT set NODE_ENV here — Next.js and the hosting platform manage it.
